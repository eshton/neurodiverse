# Copy to .env (already gitignored) and fill in real values.
# PUBLIC_ prefix required — Astro/Vite only exposes PUBLIC_* vars to client-side code,
# and the Maps JS key has to run in the browser (it's restricted by domain, not secret).
PUBLIC_GOOGLE_MAPS_API_KEY=

# Production origin for canonical URLs, Open Graph, sitemap, and robots.txt.
# Read at build time in astro.config.mjs (NOT a PUBLIC_ var — build-only).
# Set to the real domain in production (Cloudflare Pages env); falls back to a
# placeholder *.pages.dev subdomain if unset.
SITE_URL=
