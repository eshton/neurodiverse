---
import Layout from '../../../layouts/Layout.astro';
import ClinicMap from '../../../components/ClinicMap.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../../content.config';
import { placeholderFor } from '../../../lib/placeholder';
import { CATEGORY_LABELS, FIELD_LABELS, VALUE_LABELS, WEB_CATEGORIES } from '../../../lib/categories';

const BASE_FIELDS = new Set([
  'title',
  'locale',
  'topics',
  'summary',
  'tags',
  'sourceUrl',
  'coverImage',
  'ratings',
  'availability',
  'entryType',
  'parentTitle',
  'curatedBy',
  'lastReviewed',
  'lat',
  'lng',
]);

export async function getStaticPaths() {
  const paths = [];
  for (const category of CATEGORIES) {
    const items = await getCollection(category as any);
    for (const item of items) {
      const [locale, ...rest] = item.id.split('/');
      paths.push({
        params: { locale, category, slug: rest.join('/') },
        props: { item },
      });
    }
  }
  return paths;
}

const { category, locale } = Astro.params;
const { item } = Astro.props as { item: any };
const data = item.data;
const extraFields = Object.entries(data).filter(([key]) => !BASE_FIELDS.has(key));
const cover = data.coverImage ?? placeholderFor(data.providerType);
const backHref = WEB_CATEGORIES.has(category as string) ? '/web/' : '/';
const backLabel = WEB_CATEGORIES.has(category as string) ? 'Vissza a Web nézetre' : 'Vissza a térképre';

// schema.org structured data (JSON-LD) for richer search results. Type is mapped
// per category; only fields we actually have are emitted.
const SCHEMA_TYPE: Record<string, string> = {
  diagnosis: 'MedicalClinic', development: 'MedicalBusiness', schools: 'EducationalOrganization',
  communities: 'Organization', articles: 'Article', research: 'ScholarlyArticle',
  books: 'Book', movies: 'Movie', podcasts: 'PodcastSeries', videos: 'VideoObject',
  equipment: 'Product', food: 'CreativeWork',
};
const abs = (path: string) => (Astro.site ? new URL(path, Astro.site).href : undefined);
const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': SCHEMA_TYPE[category as string] ?? 'Thing',
  name: data.title,
  description: data.summary,
  inLanguage: 'hu',
};
const canonical = abs(Astro.url.pathname);
if (canonical) jsonLd.url = canonical;
if (cover && abs(cover)) jsonLd.image = abs(cover);
if (data.sourceUrl) jsonLd.sameAs = data.sourceUrl;
if (data.lat != null && data.lng != null) {
  jsonLd.geo = { '@type': 'GeoCoordinates', latitude: data.lat, longitude: data.lng };
  jsonLd.address = {
    '@type': 'PostalAddress',
    ...(data.address ? { streetAddress: data.address } : {}),
    ...(data.city ? { addressLocality: data.city } : {}),
    addressCountry: 'HU',
  };
}
if (category === 'articles') {
  if (data.author) jsonLd.author = { '@type': 'Person', name: data.author };
  if (data.publication) jsonLd.publisher = { '@type': 'Organization', name: data.publication };
  if (data.publishedDate) jsonLd.datePublished = data.publishedDate;
}
if (category === 'research') {
  if (data.authors) jsonLd.author = { '@type': 'Person', name: data.authors };
  if (data.venue) jsonLd.publisher = { '@type': 'Organization', name: data.venue };
  if (data.year) jsonLd.datePublished = String(data.year);
}
---
<Layout title={`${data.title} — Neurodiverse`} locale={locale} description={data.summary} image={cover}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <p class="mb-6">
    <a href={backHref} class="text-sm text-brand-700 dark:text-brand-300 hover:underline">
      &larr; {backLabel}
    </a>
  </p>

  <div class="flex gap-6 mb-6">
    {cover && (
      <img
        src={cover}
        alt={`${data.title} borító`}
        class="w-28 sm:w-36 h-auto rounded-lg border border-zinc-200 dark:border-zinc-800 shrink-0 object-cover"
        loading="eager"
      />
    )}
    <div class="min-w-0">
      {data.entryType === 'episode' && data.parentTitle && (
        <p class="text-sm text-sky-700 dark:text-sky-400 font-medium mb-1">
          Epizód — {data.parentTitle} · a teljes podcast/csatorna nem erről a témáról szól
        </p>
      )}
      <h1 class="text-2xl font-bold tracking-tight mb-2">{data.title}</h1>

      <div class="flex gap-2 mb-4">
        {data.topics.map((topic: string) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-300">
            {topic === 'adhd' ? 'ADHD' : 'Autizmus'}
          </span>
        ))}
        {data.availability === 'unavailable' && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-950 text-amber-700 dark:text-amber-400">
            Jelenleg nem elérhető
          </span>
        )}
      </div>

      <p class="text-zinc-700 dark:text-zinc-300">{data.summary}</p>
    </div>
  </div>

  {extraFields.length > 0 && (
    <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 text-sm mb-6">
      {extraFields.map(([key, value]) => (
        <>
          <dt class="text-zinc-500 dark:text-zinc-400">{FIELD_LABELS[key] ?? key}</dt>
          <dd>{Array.isArray(value) ? value.join(', ') : (VALUE_LABELS[String(value)] ?? String(value))}</dd>
        </>
      ))}
    </dl>
  )}

  {data.lat != null && data.lng != null && (
    <ClinicMap
      clinics={[
        { title: data.title, lat: data.lat, lng: data.lng, city: data.city, address: data.address, coverImage: cover, href: '' },
      ]}
      region={data.city === 'Budapest' ? 'budapest' : 'hungary'}
      category={category as string}
    />
  )}

  {data.availability === 'unavailable' ? (
    <p class="inline-block mb-8 px-4 py-2 rounded-lg bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 text-sm">
      Nem megvásárolható — sem antikvár, sem új könyvesboltban nem elérhető jelenleg.
      {' '}<a href={data.sourceUrl} class="text-brand-700 dark:text-brand-300 hover:underline">Legutóbb ellenőrzött forrás</a>
    </p>
  ) : (
    <a
      href={data.sourceUrl}
      class="inline-block mb-8 px-4 py-2 rounded-lg bg-brand-600 text-white text-sm font-medium hover:bg-brand-700"
    >
      Forrás megnyitása →
    </a>
  )}

  {data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      {data.tags.map((tag: string) => (
        <span class="text-xs px-2 py-0.5 rounded-full border border-zinc-200 dark:border-zinc-700 text-zinc-600 dark:text-zinc-400">
          #{tag}
        </span>
      ))}
    </div>
  )}

  <h2 class="text-lg font-semibold mb-3">Értékelések</h2>
  {data.ratings.length === 0 ? (
    <p class="text-zinc-500 dark:text-zinc-400 mb-6">Még nincs értékelés.</p>
  ) : (
    <ul class="space-y-2 mb-6">
      {data.ratings.map((rating: any) => (
        <li class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-3 text-sm">
          <div class="flex items-center justify-between">
            <span class="font-medium">{rating.source}</span>
            <span class="text-brand-700 dark:text-brand-300 font-medium">★ {rating.score}/{rating.scale}</span>
          </div>
          {rating.note && <p class="text-zinc-500 dark:text-zinc-400 mt-1">{rating.note}</p>}
          {rating.url && (
            <a href={rating.url} class="text-brand-700 dark:text-brand-300 hover:underline text-xs">
              forrás link
            </a>
          )}
        </li>
      ))}
    </ul>
  )}

  <p class="text-xs text-zinc-400 dark:text-zinc-500">
    Utoljára ellenőrizve: {data.lastReviewed.toISOString().slice(0, 10)} · Kuráció: {data.curatedBy}
  </p>
</Layout>
