---
import Layout from '../../../layouts/Layout.astro';
import ClinicMap from '../../../components/ClinicMap.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../../content.config';
import { placeholderFor } from '../../../lib/placeholder';
import { CATEGORY_LABELS, WEB_CATEGORIES, LISTING_MAP_CATEGORIES } from '../../../lib/categories';

export function getStaticPaths() {
  return CATEGORIES.map((category) => ({
    params: { locale: 'hu', category },
  }));
}

const { locale, category } = Astro.params;
const backHref = WEB_CATEGORIES.has(category as string) ? `/web/${category}` : '/map';
const backLabel = WEB_CATEGORIES.has(category as string) ? 'Vissza a Web nézetre' : 'Vissza a térképre';
const allItems = await getCollection(category as any);
const items = allItems.filter((item: any) => item.data.locale === locale);

// Topic filtering is done client-side (see the <script> below): these pages are
// statically prerendered, so a `?topic=` query param can't change the server
// output — every request gets the same HTML. The page renders all items and JS
// hides the ones that don't match, reading the initial state from the URL.
// One marker per physical site (primary + any additional `locations[]`), split
// below into Budapest vs. vidék by each *site's* own city — so a clinic with a
// Budapest department and a countryside one pins correctly on both maps.
const geoTagged = LISTING_MAP_CATEGORIES.has(category as string)
  ? items.flatMap((item: any) => {
      const href = `/${locale}/${category}/${item.id.split('/').slice(1).join('/')}/`;
      const cover = item.data.coverImage ?? placeholderFor(item.data.providerType);
      const sites = [
        { lat: item.data.lat, lng: item.data.lng, city: item.data.city, address: item.data.address },
        ...(item.data.locations ?? []).map((l: any) => ({ lat: l.lat, lng: l.lng, city: l.city, address: l.address })),
      ];
      return sites
        .filter((s: any) => s.lat != null && s.lng != null)
        .map((s: any) => ({
          title: item.data.title,
          lat: s.lat,
          lng: s.lng,
          city: s.city,
          address: s.address,
          coverImage: cover,
          href,
        }));
    })
  : [];

const budapestClinics = geoTagged.filter((c) => c.city === 'Budapest');
const countrysideClinics = geoTagged.filter((c) => c.city !== 'Budapest');
---
<Layout
  title={`${CATEGORY_LABELS[category] ?? category} — Neurodiverse`}
  locale={locale}
  description={`${CATEGORY_LABELS[category] ?? category}: kurátorolt ADHD- és autizmus-források Magyarországon. ${items.length} bejegyzés.`}
>
  <p class="mb-6">
    <a href={backHref} class="text-sm text-brand-700 dark:text-brand-300 hover:underline">
      &larr; {backLabel}
    </a>
  </p>

  <h1 class="text-2xl font-bold tracking-tight mb-4">{CATEGORY_LABELS[category] ?? category}</h1>

  <nav class="flex gap-2 mb-8" id="topic-filter">
    <button type="button" data-topic="all" class="topic-btn px-3 py-1 rounded-full text-sm">Mind</button>
    <button type="button" data-topic="adhd" class="topic-btn px-3 py-1 rounded-full text-sm">ADHD</button>
    <button type="button" data-topic="autism" class="topic-btn px-3 py-1 rounded-full text-sm">Autizmus</button>
  </nav>

  {budapestClinics.length > 0 && (
    <div class="mb-8">
      <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-2">Budapest</h2>
      <ClinicMap clinics={budapestClinics} region="budapest" category={category as string} />
    </div>
  )}

  {countrysideClinics.length > 0 && (
    <div class="mb-8">
      <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-2">Vidék</h2>
      <ClinicMap clinics={countrysideClinics} region="hungary" category={category as string} />
    </div>
  )}

  {items.length === 0 && <p class="text-zinc-500 dark:text-zinc-400">Nincs találat ehhez a szűréshez.</p>}
  <p id="topic-empty" class="hidden text-zinc-500 dark:text-zinc-400">Nincs találat ehhez a szűréshez.</p>

  <div class="grid gap-4">
    {items.map((item: any) => {
      const slug = item.id.split('/').slice(1).join('/');
      const topScore = item.data.ratings[0];
      const cover = item.data.coverImage ?? placeholderFor(item.data.providerType);
      return (
        <a
          href={`/${locale}/${category}/${slug}/`}
          data-topics={item.data.topics.join(',')}
          class="topic-card flex gap-4 rounded-xl border border-zinc-200 dark:border-zinc-800 p-5 hover:border-brand-400 hover:shadow-sm transition"
        >
          {cover && (
            <img
              src={cover}
              alt=""
              class="w-14 h-14 rounded-md border border-zinc-200 dark:border-zinc-800 shrink-0 object-cover"
              loading="lazy"
            />
          )}
          <div class="flex-1">
            <div class="flex items-start justify-between gap-4">
              <div>
                {item.data.entryType === 'episode' && item.data.parentTitle && (
                  <p class="text-xs text-sky-700 dark:text-sky-400 font-medium mb-0.5">
                    Epizód — {item.data.parentTitle}
                  </p>
                )}
                <h2 class="font-medium">{item.data.title}</h2>
                <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-1">{item.data.summary}</p>
              </div>
              {topScore && (
                <span class="shrink-0 text-sm font-medium text-brand-700 dark:text-brand-300 whitespace-nowrap">
                  ★ {topScore.score}/{topScore.scale}
                </span>
              )}
            </div>
          <div class="flex gap-2 mt-3">
            {item.data.topics.map((topic: string) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-300">
                {topic === 'adhd' ? 'ADHD' : 'Autizmus'}
              </span>
            ))}
            {item.data.availability === 'unavailable' && (
              <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-950 text-amber-700 dark:text-amber-400">
                Nem elérhető
              </span>
            )}
            </div>
          </div>
        </a>
      );
    })}
  </div>
</Layout>

<script>
  // Client-side topic filter. Static pages can't filter on a `?topic=` query
  // param at build time, so the page ships every card and JS hides the
  // non-matching ones — reading the initial topic from the URL and keeping the
  // URL in sync (without a navigation) as the pills are used.
  function initTopicFilter() {
    const bar = document.getElementById('topic-filter');
    if (!bar) return;
    const cards = document.querySelectorAll<HTMLElement>('.topic-card');
    const empty = document.getElementById('topic-empty');
    const buttons = bar.querySelectorAll<HTMLButtonElement>('.topic-btn');
    const active = 'bg-brand-600 text-white';
    const idle = 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700';

    const apply = (topic: string, updateUrl: boolean) => {
      let visible = 0;
      cards.forEach((card) => {
        const topics = (card.dataset.topics ?? '').split(',');
        const show = topic === 'all' || topics.includes(topic);
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      empty?.classList.toggle('hidden', visible > 0);
      buttons.forEach((b) => {
        const on = b.dataset.topic === topic;
        b.className = `topic-btn px-3 py-1 rounded-full text-sm ${on ? active : idle}`;
        b.setAttribute('aria-pressed', String(on));
      });
      if (updateUrl) {
        const url = new URL(location.href);
        if (topic === 'all') url.searchParams.delete('topic');
        else url.searchParams.set('topic', topic);
        history.replaceState(null, '', url);
      }
    };

    const initial = new URL(location.href).searchParams.get('topic');
    apply(initial === 'adhd' || initial === 'autism' ? initial : 'all', false);

    buttons.forEach((b) => b.addEventListener('click', () => apply(b.dataset.topic ?? 'all', true)));
  }

  document.addEventListener('astro:page-load', initTopicFilter);
</script>
