---
// /chat — conversational AI assistant backed by Ollama Cloud with tools. The
// message loop + tool execution live in the client <script> below; the LLM call
// is proxied by the /api/chat Pages Function (functions/api/chat.ts) which hides
// the API key. Content-search tools run in the browser against the preloaded
// /db/content.json, so lookups never leave the device — only the conversation
// text is sent to the model. Full-bleed like the map, so it uses MapLayout.
import MapLayout from '../layouts/MapLayout.astro';

const SUGGESTIONS = [
  'Hol kaphat a gyerekem autizmus-diagnózist a közelemben?',
  'Milyen könyvet ajánlotok felnőtt ADHD-ról?',
  'Mi a különbség a diagnózis és a fejlesztés között?',
];
---
<MapLayout
  title="Chat | Neuropont"
  description="Beszélgetős segítő ADHD- és autizmus-kérdésekhez — valódi, oldalon belüli forrásokkal."
>
  <!-- Notice banner -->
  <div class="shrink-0 bg-amber-50 dark:bg-amber-950/40 border-b border-amber-200 dark:border-amber-900 px-4 py-2 text-center text-xs text-amber-800 dark:text-amber-300">
    A beszélgetős segítő az <strong>Ollama Cloud</strong> nyelvi modelljét használja — az üzeneteid a modellhez kerülnek. A forráskeresés a böngésződben történik. Részletek az <a href="/adatvedelem/" class="underline">Adatvédelemben</a>.
  </div>

  <!-- Message thread -->
  <div
    id="chat-thread"
    class="flex-1 overflow-y-auto"
    role="log"
    aria-live="polite"
    aria-label="Beszélgetés"
  >
    <div class="max-w-2xl mx-auto px-4 py-6 space-y-4" id="chat-messages">
      <!-- assistant welcome -->
      <div class="flex gap-3">
        <div class="shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm" aria-hidden="true">✦</div>
        <div class="rounded-2xl rounded-tl-sm bg-zinc-100 dark:bg-zinc-800 px-4 py-3 text-sm text-zinc-800 dark:text-zinc-100 max-w-[85%]">
          <p>Szia! Segítek eligazodni az ADHD- és autizmus-források között Magyarországon — diagnózis, iskolák, fejlesztés, közösségek, könyvek és több.</p>
          <p class="mt-2 text-zinc-500 dark:text-zinc-400">Miben segíthetek? Válassz egy javaslatot, vagy írj szabadon.</p>
        </div>
      </div>

      <!-- suggestion chips -->
      <div class="flex flex-wrap gap-2 pl-11" id="chat-suggestions">
        {SUGGESTIONS.map((s) => (
          <button
            type="button"
            data-suggestion={s}
            class="text-left text-sm px-3 py-1.5 rounded-full border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:border-brand-400 hover:bg-brand-50 dark:hover:bg-brand-950 transition"
          >
            {s}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Composer -->
  <div class="shrink-0 border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
    <form id="chat-form" class="max-w-2xl mx-auto px-4 py-3 flex items-end gap-2">
      <label for="chat-input" class="sr-only">Írd be az üzeneted</label>
      <textarea
        id="chat-input"
        rows="1"
        placeholder="Írj egy üzenetet…"
        class="flex-1 resize-none max-h-40 rounded-2xl border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-900 px-4 py-2.5 text-sm text-zinc-800 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-brand-500"
      ></textarea>
      <button
        type="submit"
        id="chat-send"
        aria-label="Küldés"
        class="shrink-0 w-11 h-11 rounded-full bg-brand-600 text-white flex items-center justify-center hover:bg-brand-700 disabled:opacity-40 disabled:cursor-not-allowed transition"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 12l16-8-6 16-3-6-7-2z" fill="currentColor"/>
        </svg>
      </button>
    </form>
    <p class="max-w-2xl mx-auto px-4 pb-3 -mt-1 text-[11px] text-zinc-400 dark:text-zinc-500">
      A segítő nem ad orvosi diagnózist. Sürgős esetben fordulj szakemberhez.
    </p>
  </div>
</MapLayout>

<script>
  // Real conversation loop against /api/chat (a Cloudflare Pages Function that
  // proxies to Ollama Cloud and hides the API key). The tool loop runs HERE on the
  // client: the model's tool calls are executed locally against the preloaded
  // /db/content.json (see src/lib/chatTools.ts), so content lookups never leave the
  // browser — only the conversation text is sent to the model. Wired on
  // astro:page-load so it survives View Transitions.
  import { executeTool, renderToolUi } from '../lib/chatTools';
  import { canChat, grant } from '../lib/consent';

  const MAX_TOOL_ITERATIONS = 5; // cap the tool loop so it can't run away

  function initChat() {
    const form = document.getElementById('chat-form') as HTMLFormElement | null;
    if (!form) return; // not on the chat page
    const input = document.getElementById('chat-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    const messages = document.getElementById('chat-messages') as HTMLElement;
    const thread = document.getElementById('chat-thread') as HTMLElement;

    // Conversation sent to /api/chat each turn (the system prompt is added
    // server-side). Holds user/assistant/tool messages in Ollama's chat format.
    const history: any[] = [];
    let busy = false;

    const esc = (v: string) =>
      v.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
    const scrollDown = () => { thread.scrollTop = thread.scrollHeight; };

    // Minimal, SAFE markdown for assistant prose: escape everything first, then
    // re-introduce only a controlled subset — bold, links (internal or http[s]
    // only), and bullet lists. No raw HTML from the model ever reaches innerHTML.
    function renderMarkdown(src: string): string {
      const inline = (s: string) =>
        s
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m: string, label: string, url: string) => {
            const u = String(url).trim();
            if (/^\//.test(u))
              return `<a href="${u}" class="underline text-brand-700 dark:text-brand-300">${label}</a>`;
            if (/^https?:\/\//.test(u))
              return `<a href="${u}" target="_blank" rel="noopener noreferrer" class="underline text-brand-700 dark:text-brand-300">${label}</a>`;
            return label; // drop non-internal/non-http urls, keep the label text
          });
      const lines = esc(src).split(/\r?\n/);
      let html = '';
      let inList = false;
      for (const line of lines) {
        const t = line.trim();
        if (/^[-*]\s+/.test(t)) {
          if (!inList) { html += '<ul class="list-disc pl-5 my-1 space-y-0.5">'; inList = true; }
          html += `<li>${inline(t.replace(/^[-*]\s+/, ''))}</li>`;
        } else {
          if (inList) { html += '</ul>'; inList = false; }
          if (t) html += `<p class="mt-2 first:mt-0">${inline(t)}</p>`;
        }
      }
      if (inList) html += '</ul>';
      return html || '<p></p>';
    }

    // Some models render the action tools by writing inline directives in their
    // reply text — {{show_resource href="..."}} / {{link_to href="..." label="..."}}
    // — instead of emitting native tool_calls. Parse those out, run the matching
    // client tool, and splice the rendered card/link in place of the raw token.
    const DIRECTIVE = /\{\{\s*(show_resource|link_to)\s+([^}]*?)\}\}/g;
    async function renderAssistantContent(src: string): Promise<string> {
      let out = '';
      let last = 0;
      let m: RegExpExecArray | null;
      const addProse = (seg: string) => { if (seg && seg.trim()) out += renderMarkdown(seg); };
      DIRECTIVE.lastIndex = 0;
      while ((m = DIRECTIVE.exec(src)) !== null) {
        addProse(src.slice(last, m.index));
        last = DIRECTIVE.lastIndex;
        const args: Record<string, string> = {};
        const attr = /(\w+)\s*=\s*"([^"]*)"/g;
        let a: RegExpExecArray | null;
        while ((a = attr.exec(m[2])) !== null) args[a[1]] = a[2];
        try {
          const result = await executeTool(m[1], args);
          out += renderToolUi(result.render);
        } catch {
          // skip a malformed directive rather than dumping the raw token
        }
      }
      addProse(src.slice(last));
      return out || '<p></p>';
    }

    function addUser(text: string) {
      const el = document.createElement('div');
      el.className = 'flex gap-3 justify-end';
      el.innerHTML =
        `<div class="rounded-2xl rounded-tr-sm bg-brand-600 text-white px-4 py-3 text-sm max-w-[85%] whitespace-pre-wrap">${esc(text)}</div>`;
      messages.appendChild(el);
      scrollDown();
    }

    function addTyping(): HTMLElement {
      const el = document.createElement('div');
      el.className = 'flex gap-3';
      el.innerHTML =
        `<div class="shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm" aria-hidden="true">✦</div>` +
        `<div class="rounded-2xl rounded-tl-sm bg-zinc-100 dark:bg-zinc-800 px-4 py-3 text-sm text-zinc-500 dark:text-zinc-400">
           <span class="inline-flex gap-1"><span class="chat-dot">•</span><span class="chat-dot">•</span><span class="chat-dot">•</span></span>
         </div>`;
      messages.appendChild(el);
      scrollDown();
      return el;
    }

    function addAssistant(html: string) {
      const el = document.createElement('div');
      el.className = 'flex gap-3';
      el.innerHTML =
        `<div class="shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm" aria-hidden="true">✦</div>` +
        `<div class="rounded-2xl rounded-tl-sm bg-zinc-100 dark:bg-zinc-800 px-4 py-3 text-sm text-zinc-800 dark:text-zinc-100 max-w-[85%]">${html}</div>`;
      messages.appendChild(el);
      scrollDown();
    }

    // A tool's UI output (resource card / link chip), left-aligned and indented to
    // sit under the assistant avatar column (pl-11 matches the suggestion chips).
    function addToolUi(html: string) {
      if (!html) return;
      const el = document.createElement('div');
      el.className = 'pl-11';
      el.innerHTML = html;
      messages.appendChild(el);
      scrollDown();
    }

    function addError(text: string) {
      addAssistant(`<p class="text-red-600 dark:text-red-400">${esc(text)}</p>`);
    }

    // Chat consent is off: explain and offer a one-click enable (point-of-use
    // opt-in). On enable we grant the `chat` category and run onEnable (resend).
    function addChatConsentPrompt(onEnable: () => void) {
      const el = document.createElement('div');
      el.className = 'flex gap-3';
      el.innerHTML =
        `<div class="shrink-0 w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center text-sm" aria-hidden="true">✦</div>` +
        `<div class="rounded-2xl rounded-tl-sm bg-zinc-100 dark:bg-zinc-800 px-4 py-3 text-sm text-zinc-800 dark:text-zinc-100 max-w-[85%]">` +
        `<p>A beszélgetős segítő ki van kapcsolva az adatvédelmi beállításaid szerint. Bekapcsolva az üzeneteid feldolgozásra az <strong>Ollama Cloud</strong> nyelvi modellhez kerülnek.</p>` +
        `<button type="button" data-enable-chat class="mt-2 px-3 py-1.5 rounded-full bg-brand-600 text-white text-sm hover:bg-brand-700 transition">Engedélyezem</button>` +
        `</div>`;
      messages.appendChild(el);
      scrollDown();
      el.querySelector('[data-enable-chat]')?.addEventListener('click', () => {
        grant('chat');
        el.remove();
        onEnable();
      });
    }

    async function callApi(): Promise<any> {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });
      const data = await res.json().catch(() => ({ error: 'Váratlan válasz a szervertől.' }));
      if (!res.ok || data.error) throw new Error(data.error || `HTTP ${res.status}`);
      return data.message;
    }

    // Drive the model until it produces a final text answer (no more tool calls),
    // executing each tool call client-side in between. Capped by MAX_TOOL_ITERATIONS.
    async function runTurn() {
      let typing = addTyping();
      try {
        for (let i = 0; i < MAX_TOOL_ITERATIONS; i++) {
          const message = await callApi();
          history.push(message);
          const toolCalls = message?.tool_calls;
          if (Array.isArray(toolCalls) && toolCalls.length) {
            typing.remove(); // show the tool output while we work
            for (const call of toolCalls) {
              const fn = call.function || {};
              let args = fn.arguments;
              if (typeof args === 'string') {
                try { args = JSON.parse(args); } catch { args = {}; }
              }
              const result = await executeTool(fn.name, args || {});
              addToolUi(renderToolUi(result.render));
              history.push({ role: 'tool', tool_name: fn.name, content: result.content });
            }
            typing = addTyping(); // model thinks again with the tool results
          } else {
            typing.remove();
            addAssistant(await renderAssistantContent(message?.content || '…'));
            return;
          }
        }
        typing.remove();
        addAssistant('<p>Ez túl sok lépést igényelne — pontosítanád a kérdést?</p>');
      } catch (e) {
        typing.remove();
        addError('Hiba történt a válasz közben. Kérlek, próbáld újra.');
      }
    }

    function send(text: string) {
      const trimmed = text.trim();
      if (!trimmed || busy) return;
      if (!canChat()) {
        document.getElementById('chat-suggestions')?.remove();
        addChatConsentPrompt(() => send(text)); // enable, then resend the same text
        return;
      }
      document.getElementById('chat-suggestions')?.remove();
      addUser(trimmed);
      history.push({ role: 'user', content: trimmed });
      input.value = '';
      input.style.height = 'auto';
      busy = true;
      sendBtn.disabled = true;
      runTurn().finally(() => { busy = false; sendBtn.disabled = false; });
    }

    form.addEventListener('submit', (e) => { e.preventDefault(); send(input.value); });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(input.value); }
    });
    // Auto-grow textarea up to its max-height.
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 160) + 'px';
    });
    document.querySelectorAll<HTMLButtonElement>('[data-suggestion]').forEach((b) =>
      b.addEventListener('click', () => send(b.dataset.suggestion!))
    );
  }

  document.addEventListener('astro:page-load', initChat);
</script>

<style>
  /* Typing indicator: three dots pulsing in sequence. Respects reduced-motion
     via the global rule that near-zeroes animations. */
  .chat-dot { animation: chat-blink 1.2s infinite both; font-size: 1.2em; line-height: 1; }
  .chat-dot:nth-child(2) { animation-delay: 0.2s; }
  .chat-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes chat-blink { 0%, 80%, 100% { opacity: 0.25; } 40% { opacity: 1; } }
</style>
