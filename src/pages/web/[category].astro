---
// /web/<category> — one permalinked, fixed list per web content type. The tab
// bar (in WebExplorer) navigates between them; only the age filter remains.
// Replaces the old single combined /web grid with type toggles.
import MapLayout from '../../layouts/MapLayout.astro';
import WebExplorer from '../../components/WebExplorer.astro';
import DetailPanel from '../../components/DetailPanel.astro';
import { getCollection } from 'astro:content';
import { WEB_CATEGORIES, CATEGORY_LABELS } from '../../lib/categories';

const WEB = [...WEB_CATEGORIES];

export function getStaticPaths() {
  return [...WEB_CATEGORIES].map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

const entries = await getCollection(category as any, (entry: any) => entry.data.locale === 'hu');
const items = entries.map((entry: any) => ({
  title: entry.data.title,
  summary: entry.data.summary,
  coverImage: entry.data.coverImage,
  category,
  ageGroup: entry.data.ageGroup,
  entryType: entry.data.entryType,
  parentTitle: entry.data.parentTitle,
  topScore: entry.data.ratings[0],
  availability: entry.data.availability,
  // year-only (movies/research) also feeds the publication date so those lists sort too
  publishedDate: entry.data.publishedDate ?? (entry.data.year != null ? String(entry.data.year) : undefined),
  href: `/hu/${category}/${entry.id.split('/').slice(1).join('/')}/`,
}));

// Default order: newest first (publishedDate desc, dated before undated, then
// title). publishedDate strings are year-first ("YYYY"/"YYYY-MM-DD"), so a plain
// string compare is chronological. The client sort control can re-order; this is
// just the no-JS / first-paint order.
items.sort((a: any, b: any) => {
  const pa = a.publishedDate ?? '', pb = b.publishedDate ?? '';
  if (!!pa !== !!pb) return pa ? -1 : 1;
  if (!pa) return a.title.localeCompare(b.title, 'hu');
  return pb.localeCompare(pa) || a.title.localeCompare(b.title, 'hu');
});

const label = CATEGORY_LABELS[category as string] ?? category;
// The age filter only does something if the category actually has non-"both"
// items — on all-"both" categories (e.g. books, videos) it can never hide
// anything, so we don't render a dead control that looks broken.
const showAge = items.some((i: any) => i.ageGroup !== 'both');
---
<MapLayout
  title={`${label} | Neurodiverz Térkép`}
  description={`ADHD- és autizmus-témájú ${label.toLowerCase()} kurátorolt, ellenőrzött listája. ${items.length} bejegyzés.`}
>
  <WebExplorer items={items} category={category as string} categories={WEB} showAge={showAge} />
  <DetailPanel />
</MapLayout>
