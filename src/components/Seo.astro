---
// Shared <head> SEO tags, rendered by both layouts so meta/OG/canonical stay
// consistent site-wide. Pages pass a description (detail pages use the item's
// summary) and optionally an image (detail pages pass the cover) — everything
// falls back to a sensible site-level default.
interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description, image } = Astro.props;

const DEFAULT_DESCRIPTION =
  'Kurátorolt, helyhez kötött ADHD- és autizmus-forrás gyűjtemény Magyarországon: diagnózis, iskolák, fejlesztés, közösségek, könyvek, podcastok, videók és segédeszközök.';
const desc = description ?? DEFAULT_DESCRIPTION;

// Absolute URLs when `site` is configured (astro.config `site` / SITE_URL);
// falls back to the path alone so nothing breaks if it isn't.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = image ? (Astro.site ? new URL(image, Astro.site).href : image) : undefined;
---
<meta name="description" content={desc} />
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Neurodiverz Térkép" />
<meta property="og:title" content={title} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={desc} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
