---
// Per-category grid for content with no physical location. Each web category is
// its own permalinked page (/web/<category>); the tab bar navigates between them
// (plain links, not filters — "why would anyone see movies and articles
// together?"). Only the age toggle actually filters, within the one category.
import { CATEGORY_LABELS, CATEGORY_META } from '../lib/categories';

interface WebItem {
  title: string;
  summary: string;
  coverImage?: string;
  href: string;
  category: 'books' | 'podcasts' | 'videos' | 'equipment' | 'movies' | 'food' | 'articles' | 'research';
  ageGroup: 'children' | 'adults' | 'both';
  entryType: 'full' | 'episode';
  parentTitle?: string;
  topScore?: { score: number; scale: number };
  availability: 'in-stock' | 'unavailable';
  publishedDate?: string;
}

interface Props {
  items: WebItem[];
  category: string;      // the active category
  categories: string[];  // ordered list of web categories, for the tab bar
}

const { items, category, categories } = Astro.props;

const AGE_FILTERS = [
  { value: 'both', label: 'Minden korosztály' },
  { value: 'children', label: 'Gyerek' },
  { value: 'adults', label: 'Felnőtt' },
] as const;

// Cover shape per category, so cards match the real artwork instead of cropping it:
// portrait (book covers, film posters — ~2:3) and square (podcast art — 1:1) get a
// horizontal card (cover left, text right); everything else (videos = 16:9 thumbnails,
// equipment = landscape product shots) keeps the vertical landscape top-thumbnail.
const POSTER_SHAPE: Record<string, 'portrait' | 'square'> = {
  movies: 'portrait',
  books: 'portrait',
  podcasts: 'square',
};
---
<div class="shrink-0 border-b border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
  {/* Category tabs — navigation to each fixed list. Scrollable single row so it
      stays on one line on narrow screens. */}
  <nav class="flex gap-1.5 overflow-x-auto px-4 py-2.5" aria-label="Tartalomtípusok">
    {categories.map((c) => (
      <a
        href={`/web/${c}`}
        aria-current={c === category ? 'page' : undefined}
        class:list={[
          'shrink-0 text-sm px-3 py-1.5 rounded-full transition whitespace-nowrap',
          c === category
            ? 'bg-brand-600 text-white'
            : 'bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-zinc-700',
        ]}
      >
        <span aria-hidden="true">{CATEGORY_META[c]?.icon}</span> {CATEGORY_LABELS[c] ?? c}
      </a>
    ))}
  </nav>

  {/* Age filter + sort. Age toggles (left); sort by publication date (right). */}
  <div class="flex flex-wrap items-center gap-1.5 px-4 pb-2.5">
    <div class="flex flex-wrap gap-1.5" id="age-filters" role="group" aria-label="Korosztály">
      {AGE_FILTERS.map(({ value, label }) => (
        <button
          type="button"
          data-age={value}
          class="age-filter-btn text-sm px-3 py-1.5 rounded-full transition"
        >
          {label}
        </button>
      ))}
    </div>
    <label class="sm:ml-auto flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400">
      Rendezés:
      <select
        id="web-sort"
        class="rounded-full border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-1.5 text-zinc-700 dark:text-zinc-300"
      >
        <option value="newest">Legújabb elöl</option>
        <option value="oldest">Legrégebbi elöl</option>
        <option value="title">Cím szerint (A–Z)</option>
      </select>
    </label>
  </div>
</div>

<div id="web-grid" class="flex-1 overflow-y-auto p-4 bg-zinc-50 dark:bg-zinc-950">
  <p id="web-empty" class="text-zinc-500 dark:text-zinc-400 hidden">Nincs találat ehhez a korosztályhoz.</p>
  <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {items.map((item) => {
      // Portrait (posters/book covers) and square (podcast art) covers get a
      // horizontal card — cover left, text right — so they show uncropped.
      const shape = POSTER_SHAPE[item.category];
      const horizontal = !!shape;
      const imgClass = shape === 'portrait'
        ? 'w-24 shrink-0 self-start aspect-[2/3] object-cover bg-zinc-100 dark:bg-zinc-800'
        : shape === 'square'
          ? 'w-24 shrink-0 self-start aspect-square object-cover bg-zinc-100 dark:bg-zinc-800'
          : 'w-full h-32 object-cover bg-zinc-100 dark:bg-zinc-800';
      return (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        data-detail
        data-age={item.ageGroup}
        data-published={item.publishedDate ?? ''}
        data-title={item.title}
        class={`web-card flex rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 overflow-hidden hover:border-brand-400 hover:shadow-sm transition ${horizontal ? 'flex-row' : 'flex-col'}`}
      >
        {item.coverImage && (
          <img src={item.coverImage} alt="" loading="lazy" class={imgClass} />
        )}
        <div class="p-3 flex-1 flex flex-col min-w-0">
          {item.entryType === 'episode' && item.parentTitle && (
            <p class="text-xs text-sky-700 dark:text-sky-400 font-medium mb-0.5">Epizód — {item.parentTitle}</p>
          )}
          <h2 class="font-medium text-sm leading-snug">{item.title}</h2>
          <p class="text-xs text-zinc-600 dark:text-zinc-400 mt-1 line-clamp-3">{item.summary}</p>
          <div class="flex items-center gap-2 mt-auto pt-2">
            {item.topScore && (
              <span class="text-xs font-medium text-brand-700 dark:text-brand-300">
                ★ {item.topScore.score}/{item.topScore.scale}
              </span>
            )}
            {item.publishedDate && (
              <span class="text-xs text-zinc-400 dark:text-zinc-500">{item.publishedDate}</span>
            )}
            {item.availability === 'unavailable' && (
              <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-950 text-amber-700 dark:text-amber-400">
                Nem elérhető
              </span>
            )}
          </div>
        </div>
      </a>
      );
    })}
  </div>
</div>

<script>
  // Age filter only (the type filter became per-category permalink pages). Fired
  // on astro:page-load so it re-binds after every View Transitions navigation
  // (bundled module scripts run only once), and re-reads state each time.
  function initWebExplorer() {
    const ageButtons = document.querySelectorAll<HTMLButtonElement>('.age-filter-btn');
    if (!ageButtons.length) return; // not on a web category page
    const sortSelect = document.getElementById('web-sort') as HTMLSelectElement | null;

    const FILTERS_KEY = 'neuro-web-filters';
    let activeAge: 'both' | 'children' | 'adults' = 'both';
    let activeSort: 'newest' | 'oldest' | 'title' = 'newest';

    try {
      const saved = JSON.parse(localStorage.getItem(FILTERS_KEY) ?? 'null');
      if (saved?.age) activeAge = saved.age;
      if (saved?.sort) activeSort = saved.sort;
    } catch {
      // ignore corrupt/unavailable storage — fall back to the defaults
    }

    // A landing-page audience choice arrives as ?age=children|adults|both and wins
    // over saved state (an explicit fresh intent from the front-page selector).
    try {
      const urlAge = new URL(location.href).searchParams.get('age');
      if (urlAge === 'children' || urlAge === 'adults' || urlAge === 'both') activeAge = urlAge;
    } catch {
      // ignore — no URL access, keep restored/default age
    }

    function saveFilters() {
      try { localStorage.setItem(FILTERS_KEY, JSON.stringify({ age: activeAge, sort: activeSort })); } catch {}
    }

    const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>('.web-card'));
    const grid = cards[0]?.parentElement ?? null;
    const empty = document.getElementById('web-empty');

    function matchesAge(itemAge: string) {
      if (activeAge === 'both') return true;
      return itemAge === activeAge || itemAge === 'both';
    }

    function render() {
      let visible = 0;
      cards.forEach((card) => {
        const show = matchesAge(card.dataset.age!);
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      empty?.classList.toggle('hidden', visible > 0);
    }

    // Reorder card nodes in place. publishedDate is a year-first string
    // ("YYYY"/"YYYY-MM-DD"), so localeCompare is chronological; undated cards
    // always sort last (except when sorting by title).
    function sortCards() {
      if (!grid) return;
      const sorted = [...cards].sort((a, b) => {
        const pa = a.dataset.published ?? '', pb = b.dataset.published ?? '';
        const ta = a.dataset.title ?? '', tb = b.dataset.title ?? '';
        if (activeSort === 'title') return ta.localeCompare(tb, 'hu');
        if (!!pa !== !!pb) return pa ? -1 : 1;
        if (!pa) return ta.localeCompare(tb, 'hu');
        const c = pa.localeCompare(pb) || ta.localeCompare(tb, 'hu');
        return activeSort === 'oldest' ? c : -c;
      });
      sorted.forEach((card) => grid.appendChild(card));
    }

    function setActiveAgeButton(value: string) {
      ageButtons.forEach((b) => {
        const active = b.dataset.age === value;
        b.classList.toggle('bg-brand-600', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('bg-zinc-100', !active);
        b.classList.toggle('dark:bg-zinc-800', !active);
        b.classList.toggle('text-zinc-600', !active);
        b.classList.toggle('dark:text-zinc-300', !active);
        b.setAttribute('aria-pressed', String(active));
      });
    }

    ageButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeAge = btn.dataset.age as 'both' | 'children' | 'adults';
        setActiveAgeButton(activeAge);
        saveFilters();
        render();
      });
    });

    if (sortSelect) {
      sortSelect.value = activeSort;
      sortSelect.addEventListener('change', () => {
        activeSort = sortSelect.value as 'newest' | 'oldest' | 'title';
        saveFilters();
        sortCards();
      });
    }

    setActiveAgeButton(activeAge);
    saveFilters();
    sortCards();
    render();
  }

  document.addEventListener('astro:page-load', initWebExplorer);
</script>
