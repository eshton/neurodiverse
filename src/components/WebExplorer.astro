---
// Grid counterpart to MapExplorer for content that has no physical location
// (books, podcasts, videos, equipment) — same filter-bar look (type chips +
// age toggle), minus the location selector, since there's no map to recenter.
interface WebItem {
  title: string;
  summary: string;
  coverImage?: string;
  href: string;
  category: 'books' | 'podcasts' | 'videos' | 'equipment' | 'movies' | 'food' | 'articles' | 'research';
  ageGroup: 'children' | 'adults' | 'both';
  entryType: 'full' | 'episode';
  parentTitle?: string;
  topScore?: { score: number; scale: number };
  availability: 'in-stock' | 'unavailable';
}

interface Props {
  items: WebItem[];
}

const { items } = Astro.props;

const TYPE_FILTERS = [
  { category: 'podcasts', label: 'Podcastok' },
  { category: 'books', label: 'Könyvek' },
  { category: 'equipment', label: 'Eszközök' },
  { category: 'videos', label: 'Videók' },
  { category: 'movies', label: 'Filmek' },
  { category: 'food', label: 'Receptek' },
  { category: 'articles', label: 'Cikkek' },
  { category: 'research', label: 'Kutatás' },
] as const;

const AGE_FILTERS = [
  { value: 'both', label: 'Minden korosztály' },
  { value: 'children', label: 'Gyerek' },
  { value: 'adults', label: 'Felnőtt' },
] as const;
---
<div class="flex flex-wrap items-center gap-2 px-4 py-2 border-b border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
  <div class="flex gap-1.5" id="type-filters">
    {TYPE_FILTERS.map(({ category, label }) => (
      <button
        type="button"
        data-type={category}
        class="type-filter-btn text-sm px-3 py-1.5 rounded-full bg-brand-600 text-white transition"
      >
        {label}
      </button>
    ))}
  </div>

  <div class="flex gap-1.5 ml-auto pl-3 border-l border-zinc-200 dark:border-zinc-800" id="age-filters">
    {AGE_FILTERS.map(({ value, label }) => (
      <button
        type="button"
        data-age={value}
        class="age-filter-btn text-sm px-3 py-1.5 rounded-full transition"
      >
        {label}
      </button>
    ))}
  </div>
</div>

<div id="web-grid" class="flex-1 overflow-y-auto p-4 bg-zinc-50 dark:bg-zinc-950">
  <p id="web-empty" class="text-zinc-500 dark:text-zinc-400 hidden">Nincs találat ehhez a szűréshez.</p>
  <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {items.map((item) => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        data-detail
        data-category={item.category}
        data-age={item.ageGroup}
        class="web-card flex flex-col rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 overflow-hidden hover:border-brand-400 hover:shadow-sm transition"
      >
        {item.coverImage && (
          <img src={item.coverImage} alt="" class="w-full h-32 object-cover bg-zinc-100 dark:bg-zinc-800" loading="lazy" />
        )}
        <div class="p-3 flex-1 flex flex-col">
          {item.entryType === 'episode' && item.parentTitle && (
            <p class="text-xs text-sky-700 dark:text-sky-400 font-medium mb-0.5">Epizód — {item.parentTitle}</p>
          )}
          <h2 class="font-medium text-sm leading-snug">{item.title}</h2>
          <p class="text-xs text-zinc-600 dark:text-zinc-400 mt-1 line-clamp-3">{item.summary}</p>
          <div class="flex items-center gap-2 mt-auto pt-2">
            {item.topScore && (
              <span class="text-xs font-medium text-brand-700 dark:text-brand-300">
                ★ {item.topScore.score}/{item.topScore.scale}
              </span>
            )}
            {item.availability === 'unavailable' && (
              <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-950 text-amber-700 dark:text-amber-400">
                Nem elérhető
              </span>
            )}
          </div>
        </div>
      </a>
    ))}
  </div>
</div>

<script>
  // Wrapped in a function fired on astro:page-load so filtering re-binds after
  // every View Transitions navigation (bundled module scripts run only once).
  // State is re-read from localStorage on each run, so resetting it per
  // navigation is correct rather than a regression.
  function initWebExplorer() {
  const ALL_TYPES = ['podcasts', 'books', 'equipment', 'videos', 'movies', 'food', 'articles', 'research'];
  const FILTERS_KEY = 'neuro-web-filters';
  const activeTypes = new Set(ALL_TYPES);
  let activeAge: 'both' | 'children' | 'adults' = 'both';

  try {
    const saved = JSON.parse(localStorage.getItem(FILTERS_KEY) ?? 'null');
    if (saved) {
      activeTypes.clear();
      (saved.types ?? ALL_TYPES).forEach((t: string) => activeTypes.add(t));
      if (saved.age) activeAge = saved.age;
    }
  } catch {
    // ignore corrupt/unavailable storage — fall back to defaults already set above
  }

  function saveFilters() {
    localStorage.setItem(FILTERS_KEY, JSON.stringify({ types: [...activeTypes], age: activeAge }));
  }

  const cards = document.querySelectorAll<HTMLAnchorElement>('.web-card');
  const empty = document.getElementById('web-empty');

  function matchesAge(itemAge: string) {
    if (activeAge === 'both') return true;
    return itemAge === activeAge || itemAge === 'both';
  }

  function render() {
    let visible = 0;
    cards.forEach((card) => {
      const show = activeTypes.has(card.dataset.category!) && matchesAge(card.dataset.age!);
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    empty?.classList.toggle('hidden', visible > 0);
  }

  document.querySelectorAll<HTMLButtonElement>('.type-filter-btn').forEach((btn) => {
    const active = activeTypes.has(btn.dataset.type!);
    btn.classList.toggle('bg-brand-600', active);
    btn.classList.toggle('text-white', active);
    btn.classList.toggle('bg-zinc-100', !active);
    btn.classList.toggle('dark:bg-zinc-800', !active);
    btn.classList.toggle('text-zinc-600', !active);
    btn.classList.toggle('dark:text-zinc-300', !active);

    btn.addEventListener('click', () => {
      const type = btn.dataset.type!;
      if (activeTypes.has(type)) {
        activeTypes.delete(type);
        btn.classList.remove('bg-brand-600', 'text-white');
        btn.classList.add('bg-zinc-100', 'dark:bg-zinc-800', 'text-zinc-600', 'dark:text-zinc-300');
      } else {
        activeTypes.add(type);
        btn.classList.add('bg-brand-600', 'text-white');
        btn.classList.remove('bg-zinc-100', 'dark:bg-zinc-800', 'text-zinc-600', 'dark:text-zinc-300');
      }
      saveFilters();
      render();
    });
  });

  const ageButtons = document.querySelectorAll<HTMLButtonElement>('.age-filter-btn');
  function setActiveAgeButton(value: string) {
    ageButtons.forEach((b) => {
      const active = b.dataset.age === value;
      b.classList.toggle('bg-brand-600', active);
      b.classList.toggle('text-white', active);
      b.classList.toggle('bg-zinc-100', !active);
      b.classList.toggle('dark:bg-zinc-800', !active);
      b.classList.toggle('text-zinc-600', !active);
      b.classList.toggle('dark:text-zinc-300', !active);
    });
  }
  ageButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeAge = btn.dataset.age as 'both' | 'children' | 'adults';
      setActiveAgeButton(activeAge);
      saveFilters();
      render();
    });
  });
  setActiveAgeButton(activeAge);

  render();
  }

  document.addEventListener('astro:page-load', initWebExplorer);
</script>
